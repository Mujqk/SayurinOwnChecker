<Window x:Class="BazaChecker.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading..." Height="300" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Topmost="True">
    
    <Border Background="#050508" CornerRadius="20" BorderBrush="#3A1D54" BorderThickness="2">
        <Grid>
            <!-- Main Content -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                
                <!-- Animated Gradient Text "SAYURIN" -->
                <TextBlock x:Name="TitleText" Text="SAYURIN" FontSize="56" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock.Foreground>
                        <LinearGradientBrush x:Name="GradientBrush" StartPoint="0,0" EndPoint="1,0">
                            <GradientStop x:Name="Stop1" Color="#3B82F6" Offset="0"/>
                            <GradientStop x:Name="Stop2" Color="#A855F7" Offset="0.5"/>
                            <GradientStop x:Name="Stop3" Color="#EC4899" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
                
                <TextBlock Text="C H E C K E R" Foreground="#555" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                
                <!-- Loading Status -->
                <TextBlock x:Name="TxtStatus" Text="Загрузка..." Foreground="#888" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                
                <!-- Progress Bar -->
                <Border Background="#1A1A24" CornerRadius="4" Height="6" Width="300" HorizontalAlignment="Center">
                    <Border x:Name="ProgressFill" Background="#3B82F6" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                </Border>
            </StackPanel>
            
            <!-- Version -->
            <TextBlock Text="v1.0.0" Foreground="#444" FontSize="11" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,15,10"/>
        </Grid>
    </Border>
    
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <!-- Animate gradient colors for shimmer effect -->
                    <ColorAnimation Storyboard.TargetName="Stop1" Storyboard.TargetProperty="Color"
                                    From="#3B82F6" To="#EC4899" Duration="0:0:2" AutoReverse="True"/>
                    <ColorAnimation Storyboard.TargetName="Stop2" Storyboard.TargetProperty="Color"
                                    From="#A855F7" To="#3B82F6" Duration="0:0:2" AutoReverse="True"/>
                    <ColorAnimation Storyboard.TargetName="Stop3" Storyboard.TargetProperty="Color"
                                    From="#EC4899" To="#A855F7" Duration="0:0:2" AutoReverse="True"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
