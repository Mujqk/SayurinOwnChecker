<Window x:Class="BazaChecker.LanguageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Language" Height="340" Width="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        MouseLeftButtonDown="TitleBar_MouseDown">
    
    <Border CornerRadius="16" Background="#0D0D12" BorderBrush="#2A2A35" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.85"/>
        </Border.Effect>
        
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#1A1A24" CornerRadius="8" Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🌐" FontSize="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Язык интерфейса" FontSize="16" Foreground="#E5E7EB" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Language Options -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                
                <!-- English Option -->
                <Border x:Name="EnglishBorder" CornerRadius="12" Margin="0,8" Cursor="Hand" 
                        Background="#16161D" BorderBrush="#2A2A35" BorderThickness="1.5"
                        MouseLeftButtonDown="English_Click">
                    <Grid Margin="18,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="4" Background="#1F1F2A" Padding="4,2">
                            <Image Source="Assets/usa.png" Width="36" Height="24" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock Text="English" Foreground="#E5E7EB" FontSize="15" FontWeight="Medium"/>
                            <TextBlock Text="Interface language" Foreground="#6B7280" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Border x:Name="EnglishCircle" Grid.Column="2" Width="28" Height="28" CornerRadius="14" 
                                BorderThickness="2" BorderBrush="#3B3B4F" Background="Transparent">
                            <TextBlock x:Name="EnglishCheckmark" Text="✓" Foreground="White" FontSize="13" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                                       Visibility="Collapsed"/>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- Russian Option -->
                <Border x:Name="RussianBorder" CornerRadius="12" Margin="0,8" Cursor="Hand" 
                        Background="#16161D" BorderBrush="#A855F7" BorderThickness="1.5"
                        MouseLeftButtonDown="Russian_Click">
                    <Border.Effect>
                        <DropShadowEffect Color="#A855F7" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid Margin="18,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="4" Background="#1F1F2A" Padding="4,2">
                            <Image Source="Assets/russian.png" Width="36" Height="24" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock Text="Русский" Foreground="#E5E7EB" FontSize="15" FontWeight="Medium"/>
                            <TextBlock Text="Язык интерфейса" Foreground="#6B7280" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Border x:Name="RussianCircle" Grid.Column="2" Width="28" Height="28" CornerRadius="14" 
                                BorderThickness="2" BorderBrush="#A855F7" Background="#A855F7">
                            <TextBlock x:Name="RussianCheckmark" Text="✓" Foreground="White" FontSize="13" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                
            </StackPanel>
            
            <!-- Apply Button -->
            <Button Grid.Row="3" Content="Применить" Height="48" Margin="0,20,0,0" Click="Apply_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#A855F7" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#A855F7" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Foreground>
                    <SolidColorBrush Color="White"/>
                </Button.Foreground>
                <Button.FontWeight>SemiBold</Button.FontWeight>
                <Button.FontSize>14</Button.FontSize>
            </Button>
        </Grid>
    </Border>
</Window>
