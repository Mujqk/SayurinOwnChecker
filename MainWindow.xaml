					<!-- Global Footer Status -->
					<StackPanel Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,0,25,5">
						<TextBlock Name="AdminStatus" Text="✓ ADMIN MODE" FontSize="11" Foreground="#22C55E" FontWeight="Bold" Margin="0,0,8,0" />
						<TextBlock Text="v2.0.0 · Release" FontSize="9" Foreground="#444" VerticalAlignment="Center" />
					</StackPanel>
				</Grid>

				<!-- Notifications Stack -->
				<ItemsControl Name="NotificationStack" 
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Right" 
                    Margin="0,55,15,0" 
                    Grid.Column="1"
                    Grid.RowSpan="2"
                    Panel.ZIndex="1000">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Vertical" />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Name="NotifyBorder" 
                          CornerRadius="14" 
                          Margin="0,0,0,10" 
                          Width="300"
                          Opacity="{Binding OpacityValue}"
                          ClipToBounds="True">
								<Border.Background>
									<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
										<GradientStop Color="#0F0F16" Offset="0" />
										<GradientStop Color="#0A0A10" Offset="1" />
									</LinearGradientBrush>
								</Border.Background>
								<Border.BorderThickness>1</Border.BorderThickness>
								<Border.Effect>
									<DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.6" ShadowDepth="4" Direction="270" />
								</Border.Effect>
								<Border.RenderTransform>
									<ScaleTransform ScaleX="1" ScaleY="1" />
								</Border.RenderTransform>
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="RenderTransformOrigin" Value="1,0.5" />
										<Setter Property="BorderBrush" Value="#A855F7" />
										<Style.Triggers>
											<!-- Цветные контуры по типу -->
											<DataTrigger Binding="{Binding Type}" Value="Error">
												<Setter Property="BorderBrush" Value="#EF4444" />
											</DataTrigger>
											<DataTrigger Binding="{Binding Type}" Value="Warning">
												<Setter Property="BorderBrush" Value="#FACC15" />
											</DataTrigger>
											<!-- Плавное появление: scale -->
											<EventTrigger RoutedEvent="Loaded">
												<BeginStoryboard>
													<Storyboard>
														<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.92" To="1" Duration="0:0:0.3">
															<DoubleAnimation.EasingFunction>
																<BackEase EasingMode="EaseOut" Amplitude="0.3" />
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
														<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.92" To="1" Duration="0:0:0.3">
															<DoubleAnimation.EasingFunction>
																<BackEase EasingMode="EaseOut" Amplitude="0.3" />
															</DoubleAnimation.EasingFunction>
														</DoubleAnimation>
													</Storyboard>
												</BeginStoryboard>
											</EventTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>

								<Grid>


									<!-- Контент -->
									<Grid Margin="16,10,10,10">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>

										<!-- Иконка -->
										<TextBlock Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0">
											<TextBlock.Style>
												<Style TargetType="TextBlock">
													<Setter Property="Foreground" Value="#A855F7" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding Type}" Value="Error">
															<Setter Property="Foreground" Value="#EF4444" />
														</DataTrigger>
														<DataTrigger Binding="{Binding Type}" Value="Warning">
															<Setter Property="Foreground" Value="#FACC15" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</TextBlock.Style>
										</TextBlock>

										<!-- Текст -->
										<StackPanel Grid.Column="1" VerticalAlignment="Center">
											<TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,1" />
											<TextBlock Text="{Binding Message}" FontSize="10" Foreground="#888" TextWrapping="Wrap" />
										</StackPanel>

										<!-- Кнопка закрытия -->
										<Button Grid.Column="2" 
                                  Content="✕" 
                                  Foreground="#444" 
                                  FontSize="10" 
                                  Width="20" Height="20"
                                  Background="Transparent" 
                                  BorderThickness="0" 
                                  VerticalAlignment="Top" 
                                  Margin="6,-2,-2,0"
                                  Cursor="Hand"
                                  Tag="{Binding Id}"
                                  Click="CloseNotification_Click">
											<Button.Style>
												<Style TargetType="Button">
													<Setter Property="Template">
														<Setter.Value>
															<ControlTemplate TargetType="Button">
																<Border Name="bd" Background="Transparent" CornerRadius="10">
																	<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
																</Border>
																<ControlTemplate.Triggers>
																	<Trigger Property="IsMouseOver" Value="True">
																		<Setter TargetName="bd" Property="Background" Value="#20FFFFFF" />
																		<Setter Property="Foreground" Value="White" />
																	</Trigger>
																</ControlTemplate.Triggers>
															</ControlTemplate>
														</Setter.Value>
													</Setter>
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsPersistent}" Value="True">
															<Setter Property="Visibility" Value="Collapsed" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Button.Style>
										</Button>
									</Grid>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</Grid>
		</Border>
	</Grid>
</Window>